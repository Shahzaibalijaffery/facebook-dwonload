{
  "manifest_version": 3,
  "name": "Facebook Video Downloader",
  "version": "1.0.0",
  "description": "Download Facebook videos in MP4 and HLS formats",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; frame-src https://helper.addoncrop.com"
  },
  "permissions": ["activeTab", "storage", "downloads"],
  "host_permissions": [
    "*://*.facebook.com/*",
    "*://*.fb.com/*",
    "*://*.fbcdn.net/*"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.facebook.com/*", "*://*.fb.com/*"],
      "js": ["content/intercept.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://*.facebook.com/*", "*://*.fb.com/*"],
      "js": ["content/bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.facebook.com/*", "*://*.fb.com/*"],
      "js": ["content/reel-download-button.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.facebook.com/*", "*://*.fb.com/*"],
      "css": ["content/downloadNotifications.css"],
      "js": ["content/downloadNotifications.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/images/download.svg"
      ],
      "matches": ["*://*.facebook.com/*", "*://*.fb.com/*"]
    }
  ]
}
