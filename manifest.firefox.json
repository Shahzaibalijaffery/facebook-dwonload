{
  "manifest_version": 2,
  "name": "Facebook Video Downloader",
  "version": "1.0.0",
  "description": "Download Facebook videos in MP4 and HLS formats",
  "browser_specific_settings": {
    "gecko": {
      "id": "facebook-video-downloader@betterlogics",
      "strict_min_version": "109.0"
    }
  },
  "content_security_policy": "script-src 'self'; object-src 'self'; frame-src https://helper.addoncrop.com",
  "permissions": [
    "activeTab",
    "storage",
    "downloads",
    "*://*.facebook.com/*",
    "*://*.fb.com/*",
    "*://*.fbcdn.net/*"
  ],
  "background": {
    "scripts": ["background/background.js"]
  },
  "content_scripts": [
    {
      "matches": ["*://*.facebook.com/*", "*://*.fb.com/*"],
      "js": ["content/intercept.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.facebook.com/*", "*://*.fb.com/*"],
      "js": ["content/bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.facebook.com/*", "*://*.fb.com/*"],
      "js": ["content/reel-download-button.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.facebook.com/*", "*://*.fb.com/*"],
      "css": ["assets/styles/downloadNotifications.css"],
      "js": ["content/downloadNotifications.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": ["assets/images/download.svg"]
}

